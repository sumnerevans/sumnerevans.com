<aside class="webring">
  <div class="header">
    <h3>
      ARTICLES FROM BLOGS I FOLLOW
    </h3>
    <span class="attribution">
      Generated by
      <a href="https://github.com/lukehsiao/openring-rs" target="_blank" rel="external">openring-rs</a>
    </span>
  </div>
  <section class="articles">
    <ul>
      {% for article in articles %}
        <li>
          <b><a href="{{ article.link | safe }}" target="_blank" rel="external">{{ article.title | safe }}</a></b>
          <small class="source">
            via <a href="{{ article.source_link | safe }}" target="_blank" rel="external">{{ article.source_title | safe }}</a> on {{ article.timestamp | date(format="%Y-%m-%d") }}
          </small>
        </li>
      {% endfor %}
    </ul>
  </section>
</aside>
